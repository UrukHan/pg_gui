#!/bin/bash
# Route instrument and camera IPs through the local ethernet (enp0s31f6)
# instead of the USB modem (enxac0033aa9633) which is the default gateway.
if [ "$1" = "enp0s31f6" ] && [ "$2" = "up" ]; then
    ip route replace 192.168.0.64/32 dev enp0s31f6 src 192.168.0.101 metric 99
    ip route replace 192.168.0.65/32 dev enp0s31f6 src 192.168.0.101 metric 99
    ip route replace 192.168.0.68/32 dev enp0s31f6 src 192.168.0.101 metric 99
    ip route replace 192.168.0.69/32 dev enp0s31f6 src 192.168.0.101 metric 99
    ip route replace 192.168.0.70/32 dev enp0s31f6 src 192.168.0.101 metric 99
fi
